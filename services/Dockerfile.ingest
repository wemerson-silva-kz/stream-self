# Ingest precisa do FFmpeg em runtime (transcode ABR -> LL-HLS).
FROM golang:1.23-alpine AS build
WORKDIR /src
COPY go.mod go.sum* ./
RUN go mod download
COPY . .
RUN CGO_ENABLED=0 go build -o /out/app ./cmd/ingest

FROM alpine:3.20
RUN apk add --no-cache ffmpeg
COPY --from=build /out/app /usr/local/bin/app
ENTRYPOINT ["/usr/local/bin/app"]
