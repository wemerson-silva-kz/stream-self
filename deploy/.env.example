# ============================================================================
# Configuração de PRODUÇÃO — copie para deploy/.env e preencha.
#   cp .env.example .env  &&  edite  &&  docker compose -f docker-compose.prod.yml --env-file .env up -d --build
# ============================================================================

# --- App Laravel ---
APP_URL=https://seudominio.com
# Gere com:  docker compose -f docker-compose.prod.yml run --rm web php artisan key:generate --show
APP_KEY=

# --- Banco (Postgres) ---
DB_DATABASE=streamself
DB_USERNAME=streamself
DB_PASSWORD=troque-esta-senha-forte

# --- Segredos compartilhados Laravel <-> serviços Go ---
# STREAM_JWT_SECRET: MESMO valor nos dois lados; HS256 exige >= 32 bytes.
STREAM_JWT_SECRET=gere-um-segredo-de-pelo-menos-32-bytes-aqui
# INTERNAL_SECRET: autentica a rota interna usada pelo ingest p/ validar stream key.
INTERNAL_SECRET=outro-segredo-interno-forte

# --- URLs públicas do plano de vídeo/chat (atrás de TLS) ---
STREAM_ORIGIN_URL=https://cdn.seudominio.com      # edge (LL-HLS)
STREAM_CHAT_WS_URL=wss://chat.seudominio.com/ws    # serviço de chat
STREAM_RTMP_URL=rtmp://ingest.seudominio.com/live
STREAM_SRT_URL=srt://ingest.seudominio.com:9000

# Freemium global padrão (segundos); live/plano têm precedência.
STREAM_GLOBAL_FREEMIUM_SECONDS=18000

# --- Transcode ---
FFMPEG_ENCODER=libx264   # use h264_nvenc se o host tiver GPU NVIDIA

# --- Billing ---
# stub | stripe | mercadopago | asaas
BILLING_DRIVER=stub
# Preencha conforme o driver escolhido:
# STRIPE_SECRET=
# STRIPE_WEBHOOK_SECRET=
# MERCADOPAGO_TOKEN=
# ASAAS_KEY=

# --- Portas publicadas no host (ajuste atrás do seu proxy/LB) ---
WEB_PORT=8080
EDGE_PORT=8085
CHAT_PORT=8082
SRT_PORT=9000
